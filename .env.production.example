# Canopy — Production Environment Variables
# Used when deploying to Google Cloud Run.
# Set these in Cloud Run environment variables or Secret Manager.
# DO NOT commit actual values to source control.

# ── Gemini AI (set as Secret Manager secret on Cloud Run) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase (NEXT_PUBLIC_* are baked in at Docker build time) ──
# Pass as --build-arg to docker build, or set in cloudbuild.yaml substitutions.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Next.js ──
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ── Cloud Run (automatically set by Cloud Run) ──
# PORT=8080   # Injected automatically — do not set manually
